# --------------------------------------------------------------------------
# .gitignore — Files and folders Git should NOT track
# --------------------------------------------------------------------------

# ===== R session and history =====
.Rhistory
.RData
.Ruserdata
.Rapp.history

# ===== R package builds =====
*.Rcheck/
*.tar.gz
*-Ex.R

# ===== RStudio =====
.Rproj.user/

# ===== Quarto / R Markdown =====
*.html
_book/
_site/
.quarto/

# ===== Operating system files =====
.DS_Store
Thumbs.db
desktop.ini
*~
.~lock.*

# ===== Editors =====
.vscode/
.idea/
*.swp
*.swo

# ===== Raw transcriptomic data =====
# Never commit raw omics data — they are large and may have access restrictions.
# The pipeline downloads them from GEO. See data/README.md for details.
data/raw/
data/processed/
*.bam
*.bai
*.vcf
*.vcf.gz
*.fastq
*.fastq.gz
*.fq.gz
*.h5
*.bigwig
*.bw
*.CEL
*.CEL.gz
*.tsv.gz

# ===== Sensitive files =====
.env
*.key
*.pem
config.local.*
credentials.*

# ===== Intermediate results from the experiment =====
# Fitted LASSO models, predictions, and other intermediate outputs are
# heavy and reproducible. They are saved under results/intermediate/.
# Final figures (TIFF in results/figures/) and tables (XLSX in results/tables/)
# ARE tracked so reviewers can see them without re-running the pipeline.
results/intermediate/

# ===== Logs and temporary files =====
*.log
tmp/
temp/
.cache/

# ===== Exception: keep .gitkeep files =====
!.gitkeep
